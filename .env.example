# Swipall API Configuration
# Replace with your actual Swipall backend URL
SWIPALL_SHOP_API_URL=http://localhost:3001/api

# Optional: Public API URL (if different from internal URL)
# NEXT_PUBLIC_SWIPALL_SHOP_API_URL=https://api.swipall.example.com

# Optional: Custom auth token header name (defaults to "Authorization")
# SWIPALL_AUTH_TOKEN_HEADER=X-Authorization

# Optional: If your API uses Bearer token format differently
# JWT tokens are stored in httpOnly cookies via Set-Cookie headers

# Preview mode (CMS live sync) — see docs/features/preview-mode-live-cms-sync.md
# Exact origin the swip-cms-front editor is served from (no wildcard, no trailing path)
CMS_EDITOR_ORIGIN=https://cloud.swipall.io
# Shared secret used to gate /preview/home; must match the value swip-cms-front uses to build the iframe src
PREVIEW_ACCESS_SECRET=
